{
  "name": "@julianelda/scratchpad",
  "version": "1.19.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JulianElda/arche.git",
    "directory": "packages/scratchpad"
  },
  "style": "./dist/scratchpad.css",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/scratchpad.js",
  "module": "./dist/scratchpad.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    },
    "./tailwind": "./dist/tailwind.css",
    "./background": "./dist/assets/background.css"
  },
  "scripts": {
    "build": "tsgo --project ./tsconfig.lib.json && vite build && mkdir -p dist/assets && cp lib/tailwind.css dist/tailwind.css && cp lib/assets/style/background.css dist/assets/background.css",
    "dev": "vite",
    "lint": "oxlint",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 --no-open",
    "svgr": "svgr --jsx-runtime automatic --expand-props --typescript --no-prettier --out-dir lib/icons lib/assets/svg",
    "test": "vitest"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "js-cookie": "^3.0.5"
  },
  "devDependencies": {
    "@julianelda/chroma": "^1.0.0",
    "@julianelda/stilo": "^1.0.2",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@svgr/cli": "^8.1.0",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/js-cookie": "^3.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite-plugin-dts": "^5.0.0",
    "vitest-browser-react": "^2.2.0"
  },
  "peerDependencies": {
    "clsx": "^2.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
