{
  "name": "@julianelda/domos",
  "version": "1.1.1",
  "keywords": [
    "svelte"
  ],
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./tailwind": "./dist/tailwind.css"
  },
  "scripts": {
    "build": "vite build && bun run prepack",
    "build-storybook": "storybook build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "vite dev",
    "format": "oxfmt",
    "lint": "oxlint && prettier --check . && eslint .",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 --no-open",
    "test": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@julianelda/chroma": "^1.0.0",
    "@julianelda/stilo": "^1.0.2",
    "@shikijs/langs": "^4.0.1",
    "@shikijs/markdown-it": "^4.0.1",
    "@shikijs/themes": "^4.0.1",
    "codemirror": "^6.0.2",
    "markdown-it": "^14.1.1",
    "shiki": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@julianelda/lexis": "^2.5.2",
    "@lucide/svelte": "^1.16.0",
    "@playwright/test": "^1.58.1",
    "@prettier/plugin-oxc": "^0.1.3",
    "@storybook/addon-a11y": "^10.2.7",
    "@storybook/addon-svelte-csf": "^5.0.10",
    "@storybook/addon-themes": "^10.2.7",
    "@storybook/sveltekit": "^10.2.7",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24",
    "@typescript/native-preview": "^7.0.0-dev.20260521.1",
    "@vitest/browser-playwright": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-plugin-oxlint": "^1.66.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-storybook": "^10.2.7",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.58.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^4.0.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "publint": "^0.3.17",
    "storybook": "^10.2.7",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "tailwindcss": "^4.1.18",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vitest-browser-svelte": "^2.1.1"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
