{
  "name": "@julianelda/domos",
  "version": "1.3.0",
  "keywords": [
    "svelte"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JulianElda/arche.git",
    "directory": "packages/domos"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./tailwind": "./dist/tailwind.css",
    "./background": "./dist/assets/background.css"
  },
  "scripts": {
    "build": "vite build && bun run prepack",
    "build-storybook": "storybook build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "vite dev",
    "format": "oxfmt",
    "lint": "oxlint && eslint .",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 --no-open",
    "test": "vitest"
  },
  "dependencies": {
    "@julianelda/chroma": "^1.0.0",
    "@julianelda/stilo": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lucide/svelte": "^1.16.0",
    "@playwright/test": "^1.58.1",
    "@storybook/addon-svelte-csf": "^5.0.10",
    "@storybook/sveltekit": "^10.2.7",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "eslint": "^10.4.0",
    "eslint-plugin-oxlint": "^1.66.0",
    "eslint-plugin-svelte": "^3.14.0",
    "publint": "^0.3.17",
    "svelte": "^5.55.9",
    "svelte-check": "^4.3.6",
    "typescript-eslint": "^8.54.0",
    "vitest-browser-svelte": "^2.1.1"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
