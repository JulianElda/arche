{
  "name": "arche",
  "private": false,
  "description": "My development tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JulianElda/arche.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --filter='*' build",
    "check": "bun run --filter='*' check",
    "format": "bun run --filter='*' format",
    "lint": "bun run --filter='*' lint",
    "prepare": "husky",
    "test": "bun run --filter='*' test"
  },
  "dependencies": {
    "@julianelda/domos": "workspace:*",
    "@julianelda/stilo": "workspace:*"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/types": "^21.1.0",
    "@julianelda/lexis": "workspace:*",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint-plugin-perfectionist": "^5.9.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.61.1",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.0",
    "typescript-7": "npm:typescript@rc",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.13"
}
