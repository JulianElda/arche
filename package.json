{
  "name": "arche",
  "private": false,
  "description": "My development tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JulianElda/arche.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --filter='*' build",
    "check": "bun run --filter='*' check",
    "format": "bun run --filter='*' format",
    "lint": "bun run --filter='*' lint",
    "prepare": "husky",
    "test": "bun run --filter='*' test"
  },
  "dependencies": {
    "@julianelda/domos": "workspace:*",
    "@julianelda/stilo": "workspace:*"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@julianelda/lexis": "workspace:*",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-themes": "^10.4.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "24",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "@vitest/browser-playwright": "^4.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.60.0",
    "storybook": "^10.4.2",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "bun@1.3.13"
}
